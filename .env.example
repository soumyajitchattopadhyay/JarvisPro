# Groq (fast agent + tools) — required for default routing
GROQ_API_KEY=your_groq_api_key

# Colab T4 GPU backend (ngrok URL printed in Colab CELL 5)
COLAB_LLM_URL=https://your-subdomain.ngrok-free.app
COLAB_LLM_API_KEY=your_shared_secret

# Routing: auto | groq | colab | colab_fallback
LLM_ROUTING_MODE=auto
COLAB_LLM_TIMEOUT=120
COLAB_HEALTH_TTL=60