# Groq (fast agent + tools) — required for default routing
GROQ_API_KEY=your_groq_api_key

# LLM Routing: auto | groq | colab | colab_fallback
LLM_ROUTING_MODE=auto

# --- Colab GPU backend (choose ONE discovery method) ---

# Option A: Static ngrok URL (manual — update after each Colab restart)
# COLAB_LLM_URL=https://xxxx.ngrok-free.app

# Option B: Rendezvous server (automatic — recommended)
# Deploy rendezvous_server.py on Render, then set:
RENDEZVOUS_SERVER_URL=https://your-rendezvous.onrender.com
RENDEZVOUS_API_KEY=tesract-colab-key-123
RENDEZVOUS_CACHE_TTL=75
# RENDEZVOUS_STALE_SECONDS=900   # optional — rendezvous server only; marks registrations older than this as stale

# Shared secret — must match TESRACT_API_KEY in Colab Secrets
COLAB_LLM_API_KEY=tesract-colab-key-123
COLAB_LLM_TIMEOUT=180
COLAB_HEALTH_TTL=60