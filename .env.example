# --- Local-first (Ollama on Mac unified RAM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LIGHT_MODEL=llama3.2:3b
# Light model should support tools (llama3.x, qwen2.5, mistral). Heavy model is for analysis.
OLLAMA_HEAVY_MODEL=gemma2:9b
OLLAMA_TIMEOUT=90
OLLAMA_HEALTH_TTL=30

# Optional Apple Silicon MLX fallback (pip install mlx-lm)
# MLX_ENABLED=1
# MLX_MODEL_ID=mlx-community/Meta-Llama-3.1-8B-Instruct-4bit

# Optional richer web search (falls back to DuckDuckGo)
# TAVILY_API_KEY=your_tavily_key

# Optional image generation (falls back to free Pollinations API)
# OPENAI_API_KEY=your_openai_key

# --- Cloud fallbacks ---
GROQ_API_KEY=your_groq_api_key

# Colab GPU uplink (optional — for tasks exceeding local RAM)
COLAB_LLM_URL=https://xxxx.ngrok-free.app
COLAB_LLM_API_KEY=tesract-colab-key-123
COLAB_LLM_TIMEOUT=180
COLAB_HEALTH_TTL=60

# Routing: auto (local-first) | local | groq | colab | colab_fallback
LLM_ROUTING_MODE=auto

# Hybrid routing (enable on Render — prefers home Mac before cloud fallbacks)
# LOCAL_INSTANCE_URL = your Mac TESrACT URL via Cloudflare Tunnel or ngrok
ENABLE_HYBRID_ROUTING=false
# LOCAL_INSTANCE_URL=https://your-mac.trycloudflare.com
# LOCAL_INSTANCE_API_KEY=shared-secret-for-internal-invoke
# LOCAL_INSTANCE_HEALTH_TTL=30
# LOCAL_INSTANCE_TIMEOUT=90

# Future local media backends (not wired yet)
# LOCAL_IMAGE_GEN_BACKEND=mlx-stable-diffusion
# LOCAL_VIDEO_GEN_BACKEND=mlx-video

# Local in-RAM memory (ChromaDB ephemeral — tuned for 24GB MacBook)
# MEMORY_MAX_ENTRIES=500
# MEMORY_TTL_SECONDS=604800
# MEMORY_MAX_DOC_CHARS=8000
# MEMORY_MAX_MB=256
# MEMORY_CLEANUP_INTERVAL=60
# MEMORY_ENABLE_IMAGE_HOOK=false
# MEMORY_ENABLE_VIDEO_HOOK=false